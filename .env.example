# =====================================================================
# Reachly — standalone agent configuration (self-hosted .py deployment)
# Copy this file to ".env" and fill in your own values.
# Anything you leave blank is simply skipped.
# =====================================================================

# ---------------------------------------------------------------------
# 1) WHO YOU ARE  (used to write you as a thought leader)
# ---------------------------------------------------------------------
BUSINESS_NAME="Acme Robotics"
BUSINESS_WEBSITE="https://acme.example.com"
BUSINESS_SECTOR="Industrial automation / robotics"
BUSINESS_VISION="Make factory automation accessible to every small manufacturer."
BUSINESS_PRODUCT_INFO="We build affordable plug-and-play robotic arms and the software to run them."
BRAND_VOICE="Confident, practical, optimistic. No hype, no jargon."
# Comma-separated content pillars the agent rotates through day to day.
CONTENT_THEMES="industry trends, customer success, product education, founder lessons, hot takes"
# Default hashtags appended to posts (the LLM may add more, relevant ones).
DEFAULT_HASHTAGS="#automation #robotics #manufacturing"
# Language to post in.
POST_LANGUAGE="English"
# Your local timezone (IANA name) for scheduling.
TIMEZONE="Asia/Kolkata"
# Legacy single time (used only if POST_TIMES is empty).
POST_TIME="09:30"
# Multiple posts per day (comma-separated, 24h HH:MM). Hygaar default:
POST_TIMES="09:00,13:30,21:00"
# Instagram runs this many minutes AFTER each LinkedIn slot.
# With POST_TIMES above → Instagram at 09:05, 13:35, 21:05 (Asia/Kolkata).
# Instagram slot: loads pending LinkedIn caption → generates image from image_prompt → posts.
INSTAGRAM_OFFSET_MINUTES="5"

# ---- Strategy context (goals in dashboard override these when set) ----
# Repo containing AGENTS.md + product_theory.md (Hygaar on server example):
REACHLY_CONTEXT_REPO="/var/www/html/dev-env/hdb_backend"
# Optional explicit paths instead of auto-discovery:
# REACHLY_AGENTS_MD=""
# REACHLY_PRODUCT_THEORY_MD=""
# thought_leader | brand_promoter
REACHLY_POSTING_STYLE="thought_leader"

# ---- Dashboard (single-tenant control panel) ----
REACHLY_DASHBOARD_PORT="8765"
REACHLY_DASHBOARD_TOKEN="generate-a-long-random-string"

# ---------------------------------------------------------------------
# 2) LLM PROVIDER  (text generation)   -> pick ONE as primary
#    provider options: gemini | openai | anthropic
# ---------------------------------------------------------------------
LLM_PROVIDER="gemini"
LLM_MODEL=""                       # blank = sensible default per provider
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ---------------------------------------------------------------------
# 3) MEDIA GENERATION
#    image_provider: gemini | hygaar | none
#    video_provider: hygaar | none
# ---------------------------------------------------------------------
IMAGE_PROVIDER="gemini"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"   # nano banana; or gemini-3-pro-image-preview
VIDEO_PROVIDER="none"

# Optional: use your Hygaar account for image/video generation instead.
# Auth is the X-API-Key header (key looks like "hygaar_...").
HYGAAR_BASE_URL="https://dev-genai.hygaar.com"
HYGAAR_API_TOKEN=""

# ---------------------------------------------------------------------
# 4) PLATFORMS — enable the ones you want, choose mode per platform.
#    mode: api | browser | off
# ---------------------------------------------------------------------

# ---- Twitter / X ----
TWITTER_MODE="off"
# API mode (OAuth2 user-context bearer with tweet.write + media.write):
TWITTER_OAUTH2_TOKEN=""
# Browser mode (headless login) — credentials are stored locally only:
TWITTER_USERNAME=""
TWITTER_PASSWORD=""
# Optional email/phone/username for X's extra "confirm your account" step:
TWITTER_LOGIN_IDENTIFIER=""

# ---- LinkedIn ----
LINKEDIN_MODE="off"
# API mode (OAuth2, w_member_social):
LINKEDIN_ACCESS_TOKEN=""
LINKEDIN_PERSON_URN=""             # e.g. urn:li:person:xxxx  (or we auto-detect via /userinfo)
# Browser mode:
LINKEDIN_EMAIL=""
LINKEDIN_PASSWORD=""
# Browser mode: post as a Company Page you admin (exact name). Blank = personal.
LINKEDIN_POST_AS=""
# API mode: organization id to post as a Page (needs w_organization_social).
LINKEDIN_ORGANIZATION_ID=""

# ---- Instagram ----
# Browser mode: image is required — generated from LLM image_prompt at Instagram slot time.
# API mode: image must be on a public URL (see PUBLIC_MEDIA_BASE_URL).
INSTAGRAM_MODE="off"
# API mode (Instagram Graph API, business account):
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_USER_ID=""
# When using API mode, images must be reachable on a PUBLIC url.
# Provide a base url where Reachly can upload media (or leave blank to use browser mode).
PUBLIC_MEDIA_BASE_URL=""
# Browser mode:
INSTAGRAM_USERNAME=""
INSTAGRAM_PASSWORD=""

# ---------------------------------------------------------------------
# 5) AGENT BEHAVIOUR
# ---------------------------------------------------------------------
# attach_image: yes | no
# When Instagram is enabled, keep yes — IG requires an image (generated from image_prompt).
ATTACH_IMAGE="yes"
# dry_run: yes -> generate everything and print, but DO NOT actually post.
DRY_RUN="yes"
# Where browser sessions + sqlite history live.
DATA_DIR="./.reachly_data"

# ---------------------------------------------------------------------
# 6) HOSTED SAAS SERVER (only for `uvicorn server.app:app`)
# ---------------------------------------------------------------------
# Set REACHLY_ENVIRONMENT="production" in real hosted deployments. Production
# mode requires a vault key + session secret and refuses REACHLY_FREE_MODE=true.
REACHLY_ENVIRONMENT="development"
# Generate once:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
REACHLY_VAULT_KEY=""
REACHLY_SESSION_SECRET=""
REACHLY_DATABASE_URL="sqlite:///./reachly_server.db"
REACHLY_TELEGRAM_BOT_TOKEN=""
REACHLY_TELEGRAM_BOT_USERNAME=""
# Comma-separated Telegram numeric chat IDs to activate as pro in production
# while REACHLY_FREE_MODE=false. Users can find this ID after /start in logs/DB.
REACHLY_ADMIN_TELEGRAM_IDS=""
REACHLY_PUBLIC_BASE_URL="http://localhost:8000"
REACHLY_MEDIA_DIR="./reachly_media"
REACHLY_FREE_MODE="true"
REACHLY_STRIPE_SECRET_KEY=""
REACHLY_STRIPE_PRICE_ID=""
REACHLY_STRIPE_WEBHOOK_SECRET=""
